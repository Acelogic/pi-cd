{
  "name": "pi-cd",
  "version": "0.1.0",
  "description": "Pi extension that adds /cd <path> to switch the session's working directory without restarting pi. Forks the session into the target cwd, preserving conversation history.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Acelogic/pi-cd.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "cd",
    "chdir",
    "directory",
    "extension"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.67",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
